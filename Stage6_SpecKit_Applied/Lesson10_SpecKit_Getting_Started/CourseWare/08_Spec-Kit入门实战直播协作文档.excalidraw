    {
      "id": "tp_mf5f3pQRo9srvigFNP",
      "type": "text",
      "x": 1257.2870687442967,
      "y": 1296.0327333765308,
      "width": 645.39990234375,
      "height": 1350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
