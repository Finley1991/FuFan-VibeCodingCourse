      "text": "// AI 看示例 > 看描述\nfunc NewCmd() *cli.Command {\n  return &cli.Command{\n    Name: \"pkit\",\n    Action: func(\n      c *cli.Context,\n    ) error {\n      return run(\n        c.Args().Slice())\n    },\n  }\n}",
