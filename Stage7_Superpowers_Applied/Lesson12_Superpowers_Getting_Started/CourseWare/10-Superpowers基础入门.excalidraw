    },
    {
      "id": "S21_l1-b",
      "type": "text",
      "x": 119.52443024533204,
      "y": 12604.510377248107,
      "width": 391,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1a1a1a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
