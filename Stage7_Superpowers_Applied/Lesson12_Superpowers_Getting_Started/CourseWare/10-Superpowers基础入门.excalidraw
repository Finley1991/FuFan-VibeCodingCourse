      "lineHeight": 1.25,
      "index": "a00000662"
    },
    {
      "id": "S21_r1-b",
      "type": "text",
      "x": 544.524430245332,
      "y": 12604.510377248107,
      "width": 421,
      "height": 82,
      "angle": 0,
      "strokeColor": "#1a1a1a",
