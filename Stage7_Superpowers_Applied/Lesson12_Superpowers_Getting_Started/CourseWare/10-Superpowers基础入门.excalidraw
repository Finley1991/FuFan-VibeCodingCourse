      "updated": 1778223356202,
      "index": "a0000029",
      "autoResize": true
    },
    {
      "id": "S10_txt_ironlaw_body",
      "type": "text",
      "x": 497.90180896094137,
      "y": -11002.916479453179,
      "width": 234.9718780517578,
      "height": 139.2,
      "text": "用绝对化语言写死，Claude 不能「商量」\n\n🔒 HARD-GATE — 必须先写测试再写代码\n🔒 TDD — 测试驱动，禁止跳过\n🔒 Verification — 声称完成必须验证\n🔒 Root Cause — 禁止打补丁，找根因\n\n约束语言 = 绝对化 + 可检验 + 有后果",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "angle": 0,
      "strokeColor": "#991B1B",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "frameId": "S10_frm1",
      "roundness": null,
      "baseline": 12,
      "containerId": null,
      "originalText": "用绝对化语言写死，Claude 不能「商量」\n\n🔒 HARD-GATE — 必须先写测试再写代码\n🔒 TDD — 测试驱动，禁止跳过\n🔒 Verification — 声称完成必须验证\n🔒 Root Cause — 禁止打补丁，找根因\n\n约束语言 = 绝对化 + 可检验 + 有后果",
      "lineHeight": 1.45,
      "groupIds": [],
      "seed": 890227846,
      "version": 1325,
      "versionNonce": 373228385,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1778223388642,
      "index": "a00000291",
      "autoResize": true
    },
    {
      "id": "S10_rect_insight",
