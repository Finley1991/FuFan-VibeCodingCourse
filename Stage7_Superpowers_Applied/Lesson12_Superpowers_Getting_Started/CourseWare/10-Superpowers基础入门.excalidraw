    },
    {
      "id": "S21_l2-b",
      "type": "text",
      "x": 119.52443024533204,
      "y": 12750.510377248107,
      "width": 391,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1a1a1a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "S21_f1",
      "roundness": null,
      "seed": 111009,
      "version": 1344,
      "versionNonce": 1523192833,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778225369491,
      "link": null,
      "locked": false,
      "text": "已写好的代码被删 = 心理痛感\n→ 下次会主动避免触发损失感\n→ 同理：工程师不愿删自己代码\n→ 痛感是改变行为的最强驱动",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "已写好的代码被删 = 心理痛感\n→ 下次会主动避免触发损失感\n→ 同理：工程师不愿删自己代码\n→ 痛感是改变行为的最强驱动",
      "autoResize": true,
      "lineHeight": 1.25,
      "index": "a00000657"
