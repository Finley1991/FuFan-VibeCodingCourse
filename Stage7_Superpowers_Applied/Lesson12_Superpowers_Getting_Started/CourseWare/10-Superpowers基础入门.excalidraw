    },
    {
      "id": "S10_txt_insight_label",
      "type": "text",
      "x": 63.945383830483934,
      "y": -10844.73436369298,
      "width": 200,
      "height": 22,
      "text": "💡 为什么是三件套，不是单点？",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "angle": 0,
      "strokeColor": "#92400E",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "frameId": "S10_frm1",
      "roundness": null,
      "baseline": 15,
      "containerId": null,
      "originalText": "💡 为什么是三件套，不是单点？",
      "lineHeight": 1.25,
      "groupIds": [],
      "seed": 799060489,
      "version": 1276,
      "versionNonce": 919363247,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1778223356202,
      "index": "a00000293",
      "autoResize": true
    },
    {
      "id": "S10_txt_insight_body",
      "type": "text",
      "x": 63.945383830483934,
      "y": -10818.73436369298,
      "width": 840,
      "height": 68,
      "text": "单纯加 Skills → Claude 不会主动调用    |    单纯写 Iron Law → 它会忽略    |    只有 Hook 注入 + Skill 触发 + Iron Law 约束 = 闭环\nHook 是入口（每次注入）→ Skill 是工具集（按需触发）→ Iron Law 是约束语言（写死在 Skill 里）\n设计自己的 prompt 工程系统时：「入口 + 工具集 + 约束语言」三件套模式是基础架构，单点干预效果有限",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "angle": 0,
      "strokeColor": "#78350F",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "frameId": "S10_frm1",
      "roundness": null,
      "baseline": 12,
      "containerId": null,
      "originalText": "单纯加 Skills → Claude 不会主动调用    |    单纯写 Iron Law → 它会忽略    |    只有 Hook 注入 + Skill 触发 + Iron Law 约束 = 闭环\nHook 是入口（每次注入）→ Skill 是工具集（按需触发）→ Iron Law 是约束语言（写死在 Skill 里）\n设计自己的 prompt 工程系统时：「入口 + 工具集 + 约束语言」三件套模式是基础架构，单点干预效果有限",
      "lineHeight": 1.5,
      "groupIds": [],
      "seed": 308337186,
      "version": 1276,
      "versionNonce": 172667087,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
