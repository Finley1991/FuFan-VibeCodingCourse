      "text": "🏢 为什么 Jesse 用它做商业化首发",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "containerId": null,
      "originalText": "🏢 为什么 Jesse 用它做商业化首发",
      "lineHeight": 1.25,
      "index": "b9P",
      "autoResize": true
    },
    {
      "id": "S41_t_com_b",
      "type": "text",
      "x": 806.7356036353463,
      "y": 41434.583277456244,
      "width": 442,
      "height": 175,
      "angle": 0,
      "strokeColor": "#164e63",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
