      "text": "❌ 「提醒」路径为什么没用？",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "containerId": null,
      "originalText": "❌ 「提醒」路径为什么没用？",
